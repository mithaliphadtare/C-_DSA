//container ---vector
#include<iostream>
#include<vector>
using namespace std;
int main(){
//initialize the vector
vector<int> v={1,2,3,4};
v.push_back(23);
//accessing vector
for(int val:v){
    cout<<val<<" ";
}
//another way for accesing the vector
for(int i=0;i<v.size();i++){
    cout<<v[i]<<" ";
}
//deletes last element
v.pop_back();
for(int val:v){
    cout<<val<<" ";
}
//printing first and last element
cout<<v.back()<<endl;
cout<<v.front()<<endl;
//initialising the elements from the another vector
vector<int> v1(v);
for(int val:v){
    cout<<val<<" ";
}
//erase and delete
v.erase(v.begin()+1,v.begin()+3);//element at index 1 place to index 3 get delete
for(int val:v){
    cout<<val<<" ";
}
//inserting value in any position
v.insert(v.begin()+2,100);
for(int val:v){
    cout<<val<<" ";
}
//clear
v.clear();
//after clear the size gets zero but capcity not
cout<<v.size();
cout<<v.capacity()<<endl;
//finding empty or not
cout<<v.empty()<<endl;
v={1,2,3,4};
//iTERATOR--------begin and end
cout<<*(v.begin())<<endl;
cout<<*(v.end())<<endl;
//accessing using third way
vector<int>::iterator it;
for(it=v.begin();it!=v.end();it++){
    cout<<*(it)<<endl;
}
for(auto it=v.rbegin();it!=v.rend();it++){
    cout<<*(it)<<endl;
}
return 0;
}
