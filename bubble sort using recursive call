#include<iostream>
using namespace std;
void bs(int nums[], int n){
        if(n==1){
            return;
        }
        for(int j=0; j<=n-2;j++){
            if(nums[j]>nums[j+1]){
                swap(nums[j], nums[j+1]);
            }
        }
        bs(nums, n-1);
    }
  
int main(){
int n;
cin>>n;
int arr[n];
for(int i=0;i<n; i++){
cin>>arr[i];
}
bs(arr, n);
for(int i=0;i<n;i++){
cout<<arr[i];
}
return 0;
}
